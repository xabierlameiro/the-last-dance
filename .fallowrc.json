{
    "$schema": "https://docs.fallow.tools/schema.json",
    "production": true,
    "entry": [
        "src/pages/**/*.{ts,tsx}",
        "src/pages/api/**/*.ts",
        "next.config.js",
        "jest.config.js",
        "jest.setup.js",
        "jest.mock.js",
        "jest.env.setup.js",
        "playwright.config.ts",
        "e2e/**/*.ts",
        ".storybook/**/*.{js,ts,tsx}",
        "custom-*.js"
    ],
    "ignorePatterns": [
        "lighthouse/assets/**",
        "data/**",
        "migration/**",
        "storybook-static/**",
        "public/**",
        ".next/**"
    ],
    "ignoreDependencies": ["@mdx-js/loader", "@mdx-js/react"],
    "ignoreExportsUsedInFile": true
}
