        "node": ">=18.0.0",
        "npm": ">=8.0.0"
    },
    "overrides": {
        "@storybook/addon-actions": {
            "uuid": "^11.1.1"
        },
        "next": {
            "postcss": "^8.5.16"
        }
    },
    "resolutions": {
        "protobufjs": "^7.2.5",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@types/node": "^22.0.0"
    },
    "browser": {
        "fs": false,
        "path": false,
        "os": false
    }
}
