{
    "name": "the-last-dance",
    "type": "module",
    "version": "1.5.1",
    "description": "The Last Dance",
    "license": "MIT",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "debugg": "cross-env NODE_OPTIONS='--inspect' next dev",
        "prod": "npm install --legacy-peer-deps --silent",
        "build": "next build",
        "start:debugg": "cross-env NODE_OPTIONS='--inspect' next start",
        "start": "next start",
        "lint": "eslint .",
        "test": "jest --silent",
        "coverage": "rm -rf public/coverage && jest --coverage --silent && node custom-reporter.js",
        "watch": "jest --watchAll",
        "test:clear": "jest --clearCache",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "prettier": "prettier --write .",
        "jsdoc": "rm -rf public/docs && jsdoc -c jsdoc.json && node custom-docs.js",
        "lighthouse-report": "node lighthouse/assets/lighthouse.js",
        "test:e2e": "playwright test",
        "test:e2e:report": "playwright test && node custom-report.js",
        "next-info": "npx --no-install next info"
    },
    "dependencies": {
        "@code-hike/mdx": "^0.8.3",
        "@floating-ui/react": "^0.19.0",
        "@google-analytics/data": "^5.2.0",
        "@mdx-js/loader": "^2.3.0",
        "@mdx-js/react": "^2.3.0",
        "@next/mdx": "^15.4.3",
        "googleapis": "^173.0.0",
        "gray-matter": "^4.0.3",
        "jsdom": "^26.1.0",
        "next": "^15.5.9",
        "next-mdx-remote": "^6.0.0",
        "octokit": "^3.1.2",
        "react": "^19.1.0",
        "react-confetti": "^6.1.0",
        "react-dom": "^19.1.0",
        "react-icons": "^4.7.1",
        "react-intl": "^6.8.9",
        "shiki": "^0.10.1",
        "swr": "^2.0.2"
    },
    "devDependencies": {
        "@babel/core": "^7.27.1",
        "@babel/preset-typescript": "^7.18.6",
        "@jest/globals": "^29.7.0",
        "@next/eslint-plugin-next": "^15.4.3",
        "@playwright/test": "^1.57.0",
        "@storybook/addon-essentials": "^8.4.7",
        "@storybook/addon-interactions": "^8.4.7",
        "@storybook/addon-links": "^8.4.7",
        "@storybook/addons": "^6.5.14",
        "@storybook/blocks": "^8.4.7",
        "@storybook/nextjs": "^8.4.7",
        "@storybook/react": "^8.4.7",
        "@storybook/testing-library": "^0.0.13",
        "@storybook/theming": "^6.5.14",
        "@testing-library/dom": "^10.0.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.4.3",
        "@types/glob": "^8.0.0",
        "@types/node": "^22.0.0",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "chrome-launcher": "^1.2.0",
        "cross-env": "^7.0.3",
        "dotenv": "^16.4.5",
        "eslint": "^9.31.0",
        "eslint-plugin-sonarjs": "^3.0.7",
        "eslint-plugin-storybook": "^0.6.8",
        "globals": "^14.0.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.3.1",
        "jest-fetch-mock": "^3.0.3",
        "jsdoc": "^4.0.2",
        "jsdoc-babel": "^0.5.0",
        "lighthouse": "^12.2.1",
        "prettier": "^2.8.3",
        "storybook": "^8.6.15",
        "storybook-react-intl": "^1.1.1",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.63.0"
    },
